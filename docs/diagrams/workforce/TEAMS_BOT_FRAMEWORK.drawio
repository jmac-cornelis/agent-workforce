  <diagram id="tab-cmd-flow" name="Standard Command Flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title and Subtitle -->
        <mxCell id="t1" value="Teams Bot Framework — Standard Command Flow" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="500" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="User posts /stats in #agent-josephine; Bot routes to agent API and returns an Adaptive Card" style="text;html=1;fontSize=11;fontColor=#666666;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="38" width="700" height="20" as="geometry"/>
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="u1" value="User" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="80" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="u2" value="Microsoft&#xa;Teams" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="220" y="80" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="u3" value="Bot Webhook&#xa;Receiver" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="400" y="80" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="u4" value="Command&#xa;Router" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="580" y="80" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="u5" value="Agent API&#xa;(Josephine)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="780" y="80" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="u6" value="PostgreSQL" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="980" y="80" width="100" height="560" as="geometry"/>
        </mxCell>

        <!-- Messages -->
        <!-- 1. User posts "/stats" in #agent-josephine -->
        <mxCell id="m1" value="1. Post &quot;/stats&quot; in #agent-josephine" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="160" as="sourcePoint"/>
            <mxPoint x="270" y="160" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 2. Teams → Bot Webhook: message received -->
        <mxCell id="m2" value="2. Message received (webhook POST)" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="270" y="200" as="sourcePoint"/>
            <mxPoint x="450" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 3. Bot → Command Router: parse command -->
        <mxCell id="m3" value="3. Parse command" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="240" as="sourcePoint"/>
            <mxPoint x="630" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 4. Command Router: lookup channel → agent (registry) -->
        <mxCell id="m4" value="4. Lookup channel → agent (registry)" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="630" y="280" as="sourcePoint"/>
            <mxPoint x="630" y="310" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="670" y="280"/>
              <mxPoint x="670" y="310"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 5. Command Router → Agent API: GET /v1/status/stats -->
        <mxCell id="m5" value="5. GET /v1/status/stats" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="630" y="340" as="sourcePoint"/>
            <mxPoint x="830" y="340" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 6. Agent API → Command Router: stats response (JSON) -->
        <mxCell id="m6" value="6. Stats response (JSON)" style="html=1;verticalAlign=bottom;endArrow=block;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="830" y="380" as="sourcePoint"/>
            <mxPoint x="630" y="380" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 7. Command Router → Card Renderer: format Adaptive Card -->
        <mxCell id="m7" value="7. Format Adaptive Card" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="630" y="420" as="sourcePoint"/>
            <mxPoint x="630" y="450" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="670" y="420"/>
              <mxPoint x="670" y="450"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 8. Bot → Teams: post stats card to channel -->
        <mxCell id="m8" value="8. Post stats Adaptive Card" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="490" as="sourcePoint"/>
            <mxPoint x="270" y="490" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 9. Bot → PostgreSQL: log interaction (audit) -->
        <mxCell id="m9" value="9. Log interaction (audit)" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="530" as="sourcePoint"/>
            <mxPoint x="1030" y="530" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Note -->
        <mxCell id="n1" value="Card Renderer formats JSON&#xa;into Teams Adaptive Card schema" style="text;html=1;fontSize=10;fontColor=#999999;align=left;" vertex="1" parent="1">
          <mxGeometry x="1100" y="160" width="200" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="tab-approval-flow" name="Approval Workflow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title and Subtitle -->
        <mxCell id="t1" value="Teams Bot Framework — Approval Workflow" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="500" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="Humphrey requests release approval via Bot; approver responds via Adaptive Card; Bot relays decision" style="text;html=1;fontSize=11;fontColor=#666666;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="38" width="700" height="20" as="geometry"/>
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="a1" value="Agent API&#xa;(Humphrey)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="a2" value="Bot API" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="280" y="80" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="a3" value="Microsoft&#xa;Teams" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="a4" value="Release&#xa;Approver" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="720" y="80" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="a5" value="PostgreSQL" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="940" y="80" width="100" height="600" as="geometry"/>
        </mxCell>

        <!-- Messages -->
        <!-- 1. Humphrey → Bot API: POST /v1/bot/request-approval -->
        <mxCell id="m1" value="1. POST /v1/bot/request-approval&#xa;   (release promotion)" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="110" y="160" as="sourcePoint"/>
            <mxPoint x="330" y="160" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 2. Bot → PostgreSQL: create approval record -->
        <mxCell id="m2" value="2. Create approval record (status=pending)" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="200" as="sourcePoint"/>
            <mxPoint x="990" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 3. Bot → Teams: post Approval Adaptive Card -->
        <mxCell id="m3" value="3. Post Approval Adaptive Card&#xa;   [Approve] [Reject]" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="250" as="sourcePoint"/>
            <mxPoint x="550" y="250" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 4. Release Approver clicks "Approve" -->
        <mxCell id="m4" value="4. Click &quot;Approve&quot;" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="770" y="310" as="sourcePoint"/>
            <mxPoint x="550" y="310" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 5. Teams → Bot Webhook: card action received -->
        <mxCell id="m5" value="5. Card action received (approve)" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="350" as="sourcePoint"/>
            <mxPoint x="330" y="350" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 6. Bot → PostgreSQL: update approval -->
        <mxCell id="m6" value="6. Update approval (status=approved, user_id)" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="390" as="sourcePoint"/>
