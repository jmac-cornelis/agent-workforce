# ==========================================================================
# teams.env — Microsoft Teams credentials for Shannon
# ==========================================================================
# Post mode: memory (dry-run/testing), workflows (outgoing webhook), botframework (Azure Bot)
SHANNON_TEAMS_POST_MODE=memory

# Outgoing Webhook mode — uncomment and fill when ready
# SHANNON_TEAMS_OUTGOING_WEBHOOK_SECRET=<paste-from-teams-channel-config>

# Workflows mode — uncomment and fill when ready
# SHANNON_TEAMS_WORKFLOWS_WEBHOOK_URL=<paste-webhook-url>

# Bot name shown in Teams
SHANNON_TEAMS_BOT_NAME=Shannon
