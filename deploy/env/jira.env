# ==========================================================================
# jira.env — Shared deployment Jira credentials
# ==========================================================================
# Use the service account as the standing deployed identity.
# Do not place personal requester credentials in this file.

JIRA_URL=https://cornelisnetworks.atlassian.net
JIRA_DEFAULT_PROJECT=STL

# Shared automation/service account
JIRA_SERVICE_EMAIL=
JIRA_SERVICE_API_TOKEN=

# Disable fallback from requester mode to legacy JIRA_EMAIL in shared deployment
JIRA_ENABLE_LEGACY_FALLBACK=false

# Optional compatibility bridge for older code paths.
# If you still need legacy callers to work in deployment, uncomment these
# and set them to the SAME service account identity above.
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# Do not set personal requester creds in shared deployment:
# JIRA_REQUESTER_EMAIL=
# JIRA_REQUESTER_API_TOKEN=
