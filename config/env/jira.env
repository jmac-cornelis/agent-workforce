# ================================================================
# Jira Credentials
# Used by: Drucker, Gantt, Hedy, Babbage, Linnaeus, Nightingale, Brooks
# ================================================================
#
# Local/default development:
# - requester actions may fall back to JIRA_EMAIL/JIRA_API_TOKEN
# - service_account actions use JIRA_SERVICE_* when set
#
# Shared deployment:
# - set JIRA_SERVICE_* and disable legacy fallback
# - do not place personal requester creds in shared container env files

JIRA_URL=https://cornelisnetworks.atlassian.net
JIRA_DEFAULT_PROJECT=STL

# Legacy/default single-profile Jira auth (local dev compatibility)
JIRA_EMAIL=
JIRA_API_TOKEN=

# Shared automation identity
JIRA_SERVICE_EMAIL=
JIRA_SERVICE_API_TOKEN=

# Personal/requester identity (leave blank in shared deployment)
JIRA_REQUESTER_EMAIL=
JIRA_REQUESTER_API_TOKEN=

# Local dev default: keep legacy fallback enabled unless explicitly disabled
JIRA_ENABLE_LEGACY_FALLBACK=true
