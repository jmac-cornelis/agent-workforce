# ================================================================
# Shared Agent Configuration
# Non-sensitive settings common to all agents
# ================================================================

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# State persistence
STATE_BACKEND=json
PERSISTENCE_DIR=/data/state

# PostgreSQL (agent state and event bus)
DATABASE_URL=postgresql://workforce:changeme@postgres:5432/workforce

# Redis
REDIS_URL=redis://redis:6379/0

# Feature flags
ENABLE_EVENT_BUS=false
ENABLE_METRICS=true

# Agent polling defaults
DEFAULT_POLL_INTERVAL_SECONDS=300
